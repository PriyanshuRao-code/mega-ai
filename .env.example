# ============================================================
# .env.example — Multi-Agent System
# ============================================================
# Copy to .env and fill in values before running docker-compose.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All services read configuration exclusively from these vars.
# ============================================================


# ── Project ─────────────────────────────────────────────────
# Used as a prefix for container names and image tags.
COMPOSE_PROJECT_NAME=mas
IMAGE_TAG=latest

# Timezone applied to all containers (IANA format)
TZ=UTC


# ── PostgreSQL ───────────────────────────────────────────────
# Port 5432 (internal); host-mapped via POSTGRES_HOST_PORT.
POSTGRES_DB=mas_db
POSTGRES_USER=mas_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Host port to bind postgres to (useful for local inspection)
POSTGRES_HOST_PORT=5432


# ── API Server ───────────────────────────────────────────────
# Port 8000 exposed via API_HOST_PORT.
# API_SECRET_KEY must be a cryptographically random string (≥32 chars).
API_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Number of Uvicorn worker processes
API_WORKERS=2

# Set to "true" ONLY in development for hot-reload
API_RELOAD=false

# Host port for the API (accessible at http://localhost:API_HOST_PORT)
API_HOST_PORT=8000


# ── Worker ───────────────────────────────────────────────────
# No exposed port — worker communicates over the internal network.
WORKER_CONCURRENCY=4
WORKER_QUEUE=default


# ── Logging / Fluentd ────────────────────────────────────────
# Port 24224 (TCP + UDP) — Fluentd Forward protocol.
FLUENTD_HOST_PORT=24224

# Global log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ── Optional overrides ───────────────────────────────────────
# Uncomment and set if your environment requires them.

# SENTRY_DSN=https://<key>@sentry.io/<project>
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# REDIS_URL=redis://redis:6379/0
